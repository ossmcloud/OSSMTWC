                Joseph Chaney on 09/12/2025 10:32.
            </td>
        </tr>
    </table>


    <!-- SIGNED FOR TOWERCOM -->
    <table style="width:100%; border-collapse:collapse; margin-top:22px; font-family:Arial, sans-serif; font-size:11px; border:1px solid #666;">
        <tr>
            <td class="sectionHeader" align="center" style="border:1px solid #666; text-align:center; padding:5px; font-weight:bold;">
                Signed for Towercom
            </td>
        </tr>
        <tr>
            <td style="border:1px solid #666; padding:8px; background-color:gainsboro;">
                Electronically signed on behalf of Towercom by
                Morag Pollock on 12/12/2025 08:01.
            </td>
        </tr>
    </table>

    <!-- FOOTER -->
    <div style="width:100%; text-align:right; margin-top:10px; font-family:Arial, sans-serif; font-size:11px; color:#333333;">
