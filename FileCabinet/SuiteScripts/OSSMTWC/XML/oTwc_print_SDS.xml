<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE pdf PUBLIC "-//big.faceless.org//report" "report-1.1.dtd">

<pdf>
<head>
    <style type="text/css">

        body {
            font-family: Helvetica, sans-serif;
            color: #333333;
            font-size: 11px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        td {
            border: 1px solid #666666;
            padding: 4px;
            vertical-align: top;
        }

        .sectionHeader {
            background-color: #AADCFF;
            text-align: center;
            font-weight: bold;
        }

        .subHeader {
            background-color: #AADCFF;
            text-align: center;
            font-weight: bold;
        }

        .label {
            background-color: #dcdcdc;
        }

    </style>
</head>

<body padding="20">
    <!-- HEADER -->
    <table border="0">
        <tr>
            <td border="0" width="70%">
                <font size="12">
                    <b>SITE DETAILS SCHEDULE (SDS)</b>
                </font>
            </td>
            <td border="0" width="30%" align="right">
                <img src="https://9061443-sb1.app.netsuite.com/core/media/media.nl?id=21788&amp;c=9061443_SB1&amp;h=9K50eGpbmS68ktYJKqc2crZrZXhyOACwey9FegJNb6Se6Okm" height="30%;" width="80%" />
            </td>
        </tr>
    </table>
    <br />

    <!-- AGREEMENT TEXT -->
    <table border="0">
        <tr>
            <td border="0" align="center">
                This is an SDS issued pursuant and subject to the
                <b>Master Services and Licence Agreement</b>
                (the <b>"MSLA"</b>)
                <br />
                between Towercom Limited and the
                <b>Operator dated 03/11/2011</b>
            </td>
        </tr>
    </table>

    <!-- SITE DETAILS -->
    <table>
        <tr><td align="center" colspan="6" class="sectionHeader"> Site Details </td></tr>
        <tr>
            <td width="12%" class="label" align="right"> Site Name </td>
            <td width="20%"> ${requestJSON.siteDetails[0].site_name} </td>
            <td width="20%" class="label" align="right"> Site ID: </td>
            <td width="20%"> ${requestJSON.siteDetails[0].site_id} </td>
            <td width="20%" class="label" align="right"> Operator Site ID: </td>
            <td width="20%"> ${requestJSON.sdsData.operatorSiteId} </td>
        </tr>
        <tr>
            <td class="label" align="right">Site Address:</td>
            <td colspan="5">
                <#if requestJSON.siteDetails[0].address?has_content && requestJSON.siteDetails[0].address != "null"> ${requestJSON.siteDetails[0].address} </#if>
                <#if requestJSON.siteDetails[0].add_zipcode?has_content && requestJSON.siteDetails[0].add_zipcode != "null">, ${requestJSON.siteDetails[0].add_zipcode} </#if>
                <#if requestJSON.siteDetails[0].add_county?has_content && requestJSON.siteDetails[0].add_county != "null">, ${requestJSON.siteDetails[0].add_county} </#if>
            </td>
        </tr>
        <tr>
            <td class="label" align="right"> Coordinates: </td>
            <td border-right ="0"> Easting: ${requestJSON.siteDetails[0].easting} </td>
            <td border-left ="0"> Northing: ${requestJSON.siteDetails[0].northing} </td>
            <td border-right ="0" colspan="2"> Latitude: ${requestJSON.siteDetails[0].latitude} </td>
            <td border-left ="0"> Longitude: ${requestJSON.siteDetails[0].longitude} </td>
        </tr>
    </table>

    <br />
    <!-- DETAILS OF THE PARTIES -->
    <table>
        <tr> <td align="center" colspan="4" class="sectionHeader"> Details of the Parties </td> </tr>
        <tr>
            <td align="center" colspan="2" width="50%" class="subHeader"> Licensor: </td>
            <td align="center" colspan="2" width="50%" class="subHeader"> Operator: </td>
        </tr>
        <tr>
            <td colspan="2" style="line-height: 16px;">
                Name: Towercom Limited
                <br />
                Company Number: 439951
                <br />
                Registered Office: 2 Grand Canal Square, Dublin 2
                <br />
                <br />
                Whose address for correspondence is:
                <br />
                Usher House, Main Street, Dundrum, Dublin 14
            </td>
            <td colspan="2" style="line-height: 16px;">
                Name: Vodafone Ireland Limited
                <br />
                Company Number: 326967
                <br />
                Registered Office: Mountainview, Leopardstown, Dublin 18
                <br />
                <br />
                Whose address for correspondence is:
                <br />
                Mountainview, Leopardstown, Dublin 18
            </td>
        </tr>
        <tr>
            <td width="18%" class="label" align="right"> SRF Number: </td>
            <td width="32%"> S7507 </td>
            <td width="18%" class="label" align="right"> SRF Approved: </td>
            <td width="32%"> 03-12-2025 </td>
        </tr>
        <tr>
            <td class="label" align="right"> Drawing ref: </td>
            <td> ${requestJSON.sdsData.drawingReference} </td>
            <td colspan="2"> The drawing referenced forms an integral part of the SDS and illustrates the equipment licenced and/or proposed for removal. </td>
        </tr>
        <tr>
            <td colspan="2" class="label" align="right"> Site Access Reference Documents </td>
            <td colspan="2"> TCO16_TKE1019 Site Access Info Dunmurry Hill.pdf </td>
        </tr>

    </table>

    <!-- TOWER MOUNTED EQUIPMENT -->
    <table style="width:100%; border-collapse:collapse; margin-top:14px; font-family:Arial, sans-serif; font-size:10px; border:1px solid #666;">

        <!-- Section Header -->
        <tr>
            <td class="sectionHeader" colspan="16" align="center" style="border:1px solid #666; text-align:center; font-weight:bold; padding:5px;"> Tower Mounted Equipment </td>
        </tr>

        <!-- Column Headers -->
        <tr class="subHeader" style="text-align:center; font-weight:bold;">
            <td style="border:1px solid #666; padding:4px;">Status</td>
            <td style="border:1px solid #666; padding:4px;">SRF ID</td>
            <td style="border:1px solid #666; padding:4px;">ID</td>
            <td style="border:1px solid #666; padding:4px;">Type</td>
            <td style="border:1px solid #666; padding:4px;">Description</td>
            <td style="border:1px solid #666; padding:4px;"> Length<br />(mm) </td>
            <td style="border:1px solid #666; padding:4px;"> Width<br />(mm) </td>
            <td style="border:1px solid #666; padding:4px;"> Depth<br />(mm) </td>
            <td style="border:1px solid #666; padding:4px;"> Equipment<br />Height (m) </td>
            <td style="border:1px solid #666; padding:4px;"> Weight<br />(kg) </td>
            <td style="border:1px solid #666; padding:4px;">Azimuth</td>
            <td style="border:1px solid #666; padding:4px;">B-End</td>
            <td style="border:1px solid #666; padding:4px;">Location</td>
            <td style="border:1px solid #666; padding:4px;"> Inventory<br />Flag </td>
            <td style="border:1px solid #666; padding:4px;"> Atme<br />Count </td>
            <td style="border:1px solid #666; padding:4px;"> Feeder<br />Count </td>
        </tr>

        <#list requestJSON.srfItems as srfItems> 
        <tr <#if srfItems_index % 2 == 0>background-color="#C8D8E5"</#if>>
            <#if srfItems.step_type != "3">
                <td style="border:1px solid #666; padding:4px;">${srfItems.status}</td>
                <td style="border:1px solid #666; padding:4px;">[${srfItems.srf_id}]</td>
                <td style="border:1px solid #666; padding:4px;">${srfItems.id}</td>
                <td style="border:1px solid #666; padding:4px;">${srfItems.type}</td>
                <td style="border:1px solid #666; padding:4px;">${srfItems.description}</td>
                <td style="border:1px solid #666; padding:4px;">${srfItems.length}</td>
                <td style="border:1px solid #666; padding:4px;">${srfItems.width}</td>
                <td style="border:1px solid #666; padding:4px;">${srfItems.depth}</td>
                <td style="border:1px solid #666; padding:4px;">${srfItems.equip_height}</td>
                <td style="border:1px solid #666; padding:4px;">${srfItems.weight}</td>
                <td style="border:1px solid #666; padding:4px;">${srfItems.azimuth}</td>
                <td style="border:1px solid #666; padding:4px;">${srfItems.b_end}</td>
                <td style="border:1px solid #666; padding:4px;">${srfItems.location}</td>
                <td style="border:1px solid #666; padding:4px;">${srfItems.inventory_flag}</td>
                <td style="border:1px solid #666; padding:4px;">
                <#if srfItems.step_type == "2" > 
                    1
                <#else>
                    0
                </#if>
                </td>
                <td style="border:1px solid #666; padding:4px;">${srfItems.feeder_count}</td>
            </#if>
        </tr>
        </#list>

    </table>

    <!-- GROUND / INDOOR EQUIPMENT -->
    <table style="width:100%; border-collapse:collapse; margin-top:14px; font-family:Arial, sans-serif; font-size:10px; border:1px solid #666;">
        <tr>
            <td class="sectionHeader" align="center" colspan="10" style="border:1px solid #666; text-align:center; font-weight:bold; padding:5px;"> Ground/Indoor Equipment </td>
        </tr>
        <tr class="subHeader" style="text-align:center; font-weight:bold;">
            <td style="border:1px solid #666; padding:4px;">Status</td>
            <td style="border:1px solid #666; padding:4px;">SRF ID</td>
            <td style="border:1px solid #666; padding:4px;">ID</td>
            <td style="border:1px solid #666; padding:4px;">Type</td>
            <td style="border:1px solid #666; padding:4px;">Description</td>
            <td style="border:1px solid #666; padding:4px;">Length</td>
            <td style="border:1px solid #666; padding:4px;">Width</td>
            <td style="border:1px solid #666; padding:4px;">Height</td>
            <td style="border:1px solid #666; padding:4px;">Location</td>
            <td style="border:1px solid #666; padding:4px;">Inventory Flag</td>
        </tr>
        <#list requestJSON.srfItems as srfItems>
            <tr>
                <#if srfItems.step_type == "3">
                    <td style="border:1px solid #666; padding:4px;">${srfItems.status}</td>
                    <td style="border:1px solid #666; padding:4px;">${srfItems.srf_id}</td>
                    <td style="border:1px solid #666; padding:4px;">${srfItems.id}</td>
                    <td style="border:1px solid #666; padding:4px;">${srfItems.type}</td>
                    <td style="border:1px solid #666; padding:4px;">${srfItems.description}</td>
                    <td style="border:1px solid #666; padding:4px;">${srfItems.length}</td>
                    <td style="border:1px solid #666; padding:4px;">${srfItems.width}</td>
                    <td style="border:1px solid #666; padding:4px;">${srfItems.equip_height}</td>
                    <td style="border:1px solid #666; padding:4px;">${srfItems.location}</td>
                    <td style="border:1px solid #666; padding:4px;">${srfItems.inventory_flag}</td>
                </#if>
            </tr>
        </#list>
    </table>

    <!-- POWER SUPPLY -->
    <table style="width:100%; border-collapse:collapse; margin-top:14px; font-family:Arial, sans-serif; font-size:11px; border:1px solid #666;">
        <tr>
            <td class="sectionHeader" align="center" colspan="2" style="border:1px solid #666; text-align:center; padding:5px; font-weight:bold;"> Power Supply </td>
        </tr>
        <tr>
            <td style="width:50%; border:1px solid #666; padding:7px; background-color:gainsboro;"> Towercom Temp Supply Required: </td>
            <td style="width:50%; border:1px solid #666; padding:7px;"> No </td>
        </tr>
        <tr>
            <td style="border:1px solid #666; padding:7px; background-color:gainsboro;"> Other (please specify): </td>
            <td style="border:1px solid #666; padding:7px;"> Temporary power connection from Towercom. <br/> ${requestJSON.sdsData.powerSupplyComments}</td>
        </tr>
    </table>

    <!-- FIBRE -->
    <table style="width:100%; border-collapse:collapse; margin-top:22px; font-family:Arial, sans-serif; font-size:11px; border:1px solid #666;">
        <tr>
            <td class="sectionHeader" align="center" colspan="4" style="border:1px solid #666; text-align:center; padding:5px; font-weight:bold;"> Fibre </td>
        </tr>
        <tr>
            <td style="width:25%; border:1px solid #666; padding:7px; background-color:gainsboro;"> Fibre Rights: </td>
            <td style="width:25%; border:1px solid #666; padding:7px;"> <#if requestJSON.sdsData.fibreRights == "T"> Yes <#elseif requestJSON.sdsData.fibreRights == "F"> No </#if> </td>
            <td style="width:25%; border:1px solid #666; padding:7px; background-color:gainsboro;"> Fibre Duct Route: </td>
            <td style="width:25%; border:1px solid #666; padding:7px;"> ${requestJSON.sdsData.fibreDuctRoute} </td>
        </tr>
        <tr>
            <td style="border:1px solid #666; padding:7px; background-color:gainsboro;"> Fibre Provider: </td>
            <td style="border:1px solid #666; padding:7px;"> ${requestJSON.sdsData.fibreProvider} </td>
            <td style="border:1px solid #666; padding:7px; background-color:gainsboro;"> Other Provider: </td>
            <td style="border:1px solid #666; padding:7px;"> ${requestJSON.sdsData.otherProvider} </td>
        </tr>
        <tr>
            <td style="border:1px solid #666; padding:7px; background-color:gainsboro;"> Fibre Conditions: </td>
            <td colspan="3" style="border:1px solid #666; padding:7px;"> ${requestJSON.sdsData.notesConditions} </td>
        </tr>

    </table>

    <!-- LICENCE FEES -->
    <table style="width:100%; border-collapse:collapse; margin-top:22px; font-family:Arial, sans-serif; font-size:11px; border:1px solid #666;">
        <tr>
            <td class="sectionHeader" align="center" colspan="8" style="border:1px solid #666; text-align:center; padding:5px; font-weight:bold;">
                Licence Fees
            </td>
        </tr>

        <tr>
            <td style="border:1px solid #666; padding:7px; width:15%; background-color:gainsboro;">
                Previous Licence Fee:
            </td>
            <td style="border:1px solid #666; padding:7px; width:10%;">
                €${requestJSON.sdsData.previousLicenceFee}
            </td>
            <td style="border:1px solid #666; padding:7px; width:15%; background-color:gainsboro;">
                Fee Reduction:
            </td>
            <td style="border:1px solid #666; padding:7px; width:10%;">
                €${requestJSON.sdsData.feeReduction}
            </td>
            <td style="border:1px solid #666; padding:7px; width:15%; background-color:gainsboro;">
                Fee Uplift:
            </td>
            <td style="border:1px solid #666; padding:7px; width:10%;">
                €${requestJSON.sdsData.feeUplift}
            </td>
            <td style="border:1px solid #666; padding:7px; width:15%; background-color:gainsboro;">
                Licence Fee:
            </td>
            <td style="border:1px solid #666; padding:7px; width:10%;">
                €${requestJSON.sdsData.newLicenceFee}
            </td>
        </tr>
        <tr>
            <td colspan="1"
                style="border:1px solid #666; padding:7px; background-color:gainsboro;">
                SDS Commencement Date:
            </td>
            <td colspan="7" style="border:1px solid #666; padding:7px;">
                ${requestJSON.sdsData.commencementDate}
            </td>
        </tr>

        <tr>
            <td colspan="8"
                style="border:1px solid #666; padding:10px 12px; background-color:gainsboro;">
                    ${requestJSON.sdsData.feeChangeBreakdown}
            </td>
        </tr>
    </table>

    <!-- SDS CONDITIONS -->
    <table style="width:100%; border-collapse:collapse; margin-top:22px; font-family:Arial, sans-serif; font-size:11px;">
        <tr>
            <td class="sectionHeader" align="center" style="border:1px solid #666; padding:5px; font-weight:bold; text-align:center;">
                SDS Conditions
            </td>
        </tr>
        <tr>
            <td style="background-color:#d9d9d9; padding:8px; border-left:1px solid #666; border-right:1px solid #666;">
                <table style="width:100%; border-collapse:collapse;">
                    <tr>
                        <td border="0" style="padding-bottom:6px;">
                            1. This SDS becomes effective on the SDS commencement date and supersedes any previous SDS in respect of this site.
                        </td>
                    </tr>
                    <tr>
                        <td border="0" style="padding-bottom:6px;">
                            2. The effective date for additional equipment is the date the SRF is approved.
                        </td>
                    </tr>
                    <tr>
                        <td border="0">
                            3. The effective date for equipment removals is the date the equipment is removed.
                        </td>
                    </tr>
                </table>
            </td>
        </tr>

        <!-- White Section -->
        <tr>
            <td style="padding:8px; border:1px solid #666; border-top:none;">

                <table style="width:100%; border-collapse:collapse;">

                    <tr>
                        <td border="0" style="font-weight:bold; padding-bottom:8px;">
                            Additional SRF Specific Conditions
                        </td>
                    </tr>

                    <tr>
                        <td border="0" style="padding-left:15px; padding-bottom:2px;">
                            • Access shown in blue on the following:
                        </td>
                    </tr>

                    <tr>
                        <td border="0" style="padding-left:35px; padding-bottom:8px;">
                            Access Drawing : TKE1019-TCF01 Rev. 1.0
                        </td>
                    </tr>

                    <tr>
                        <td border="0" style="padding-left:15px; padding-bottom:2px;">
                            • Fibre access in accordance with Clause 4 of the MSLA, and shown in red on the following:
                        </td>
                    </tr>

                    <tr>
                        <td border="0" style="padding-left:35px;">
                            Fibre Drawing : TKE1019-TCF01 Rev. 1.0
                        </td>
                    </tr>

                </table>

            </td>
        </tr>

    </table>

    <!-- SIGNED FOR OPERATOR -->
    <table style="width:100%; border-collapse:collapse;margin-top:22px; font-family:Arial, sans-serif; font-size:11px; border:1px solid #666;">
